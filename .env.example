# Slack credentials. Both required for Socket Mode.
# Bot token (xoxb-...): from your Slack app's "OAuth & Permissions" page.
SLACK_BOT_TOKEN=

# App-level token (xapp-...) with connections:write scope:
# from your Slack app's "Basic Information" page.
SLACK_APP_TOKEN=

# LLM. Pythia talks to any OpenAI-compatible endpoint.
# OpenRouter is the default; swap base_url + model for OpenAI, Azure, Ollama, vLLM, etc.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=anthropic/claude-sonnet-4.5

# Optional: path to a file whose contents replace the default system prompt.
# PYTHIA_SYSTEM_PROMPT_FILE=/etc/pythia/system_prompt.md
