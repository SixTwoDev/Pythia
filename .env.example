# Slack credentials. Both required for Socket Mode.
# Bot token (xoxb-...): from your Slack app's "OAuth & Permissions" page.
SLACK_BOT_TOKEN=

# App-level token (xapp-...) with connections:write scope:
# from your Slack app's "Basic Information" page.
SLACK_APP_TOKEN=

# LLM. Pythia talks to any OpenAI-compatible endpoint.
# OpenRouter is the default; swap base_url + model for OpenAI, Azure, Ollama, vLLM, etc.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=anthropic/claude-sonnet-4.5

# Optional: path to a file whose contents replace the default system prompt.
# PYTHIA_SYSTEM_PROMPT_FILE=/etc/pythia/system_prompt.md

# Optional: path to a JSON file declaring MCP servers, in Claude Desktop's
# `mcpServers` shape. See the README for an example.
# MCP_SERVERS_CONFIG=/etc/pythia/mcp-servers.json

# Optional: comma-separated list of git repos to clone on startup. Each entry
# is either NAME=URL or just URL (name auto-derived from the last path segment).
# Pythia exposes search_code(repo, query) and read_file(repo, path) tools to
# the LLM for these. Requires git and ripgrep on PATH.
# CODEBASE_REPOS=api=git@github.com:acme/api.git,web=https://github.com/acme/web.git

# How often (in seconds) to re-fetch each codebase repo and hard-reset to the
# remote default branch. Default 3600 (every hour). Set to 0 to disable
# auto-refresh entirely (clones stay frozen at boot until pod restart).
# CODEBASE_REFRESH_INTERVAL_SECONDS=3600

# Optional: comma-separated list of Slack channel IDs the bot will respond in.
# Mentions in any other channel are silently ignored. Leave unset for "any
# channel I'm invited to". Set to "" (empty) to mute the bot entirely.
# PYTHIA_ALLOWED_CHANNELS=C0123456,C7890ABC

# How long a single LLM call may take before it's cancelled and retried.
# Default 60s. Bump this if you run very tool-heavy multi-turn agents on a
# slow model.
# LLM_TIMEOUT_SECONDS=60

# Total tries per Slack mention (initial + retries). Default 4. Failures use
# full-jitter exponential backoff capped at 30s; if every attempt fails the
# placeholder reply is updated with a friendly error and the failure logged.
# LLM_MAX_ATTEMPTS=4
